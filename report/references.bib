@article{yang2024,
  author   = {Yang, Wei-An and Lautan, Devin and Weng, Tong-Wei and LIn, Wan-Chun and Kao, Yamin and Chen, Chien-Chang},
  title    = {Global Convolutional Self-Action Module for Fast Brain Tumor Image Segmentation},
  journal  = {IEEE Transactions on Emerging Topics in Compulational Intelligence},
  volume   = {8},
  number   = {6},
  pages    = {3848-3859},
  year     = {2024},
  url      = {https://doi.org/10.1109/tetci.2024.3375075},
  doi      = {https://doi.org/10.1109/tetci.2024.3375075},
  abstract = {Integrating frameworks of Fermi normalization and fast data density functional transform (fDDFT), we established a new global convolutional self-action module to reduce the computational complexity in modern deep convolutional neural networks (CNNs). The Fermi normalization conflates mathematical properties of sigmoid function and z-score normalization with high efficiency. Global convolutional kernels embedded in the fDDFT simultaneously extract global features from whole input images through long-range dependency.}
}

